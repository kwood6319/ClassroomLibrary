<h2>Add a New Book</h2>
<%= simple_form_for @book do |f| %>
  <%= f.input :title %>
  <%= f.input :author_id, collection: @authors, include_blank: true  %>
  <br>
  <p>Or create a new author:</p>
  <%= f.input :new_author_first_name %>
  <%= f.input :new_author_second_name %>
  <%= f.button :submit, "Save", class: "btn btn-primary" %>
<% end %>

<div class="checkedout-container">
  <h2 class="subtitle">Checked out books</h2>
  <% @loans.each do |loan|%>
    <div class="border mb-2">
      <div class="row">
        <%= loan.student.name%>
      </div>
      <div class="row">
        <div class="col-6">
          <%= loan.book.title %>
        </div>
        <div class="col-6">
          <%= loan.date_due %>
        </div>
      </div>
    </div>
  <% end %>
</div>
